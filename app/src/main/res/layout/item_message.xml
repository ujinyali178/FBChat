<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:paddingVertical="4dp" android:paddingHorizontal="48dp">
    <LinearLayout android:id="@+id/message_container"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="12dp"
        android:background="@drawable/bg_received"
        android:elevation="1dp" android:maxWidth="280dp">
        <TextView android:id="@+id/sender_name"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="@color/fb_blue"
            android:textStyle="bold" />
        <TextView android:id="@+id/message_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="15sp" android:textColor="@color/gray_dark"
            android:layout_marginTop="2dp" />
        <TextView android:id="@+id/message_time"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="@color/gray_medium"
            android:layout_marginTop="4dp" />
    </LinearLayout>
</FrameLayout>
